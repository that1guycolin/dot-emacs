# -*- mode: snippet -*-
# name: argparse getopt for functions
# key: argparsefunc
# --

PARSED=$(getopt -o ${1:short-flags} -l ${2:long-flags} -- "$@") || {
    usage
    return 1
}
eval set -- "$PARSED"

while true; do
    case "\$1" in
        $0

        -h | --help)
	    usage
	    return 0
	    ;;
	--)
	    shift
	    break
	    ;;
	*)
	    echo "ERROR: Invalid option: \$1" >&2
	    usage
	    return 1
	    ;;
    esac
done