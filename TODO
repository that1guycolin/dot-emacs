*** TODO Use-package call for org-node
:PROPERTIES:
:ORG_GTD:  Actions
:ID:       Use-package-call-for-org-node-2026-04-21-13-28-08
:TRIGGER:  self org-gtd-update-project-after-task-done!
:ORG_GTD_PROJECT_IDS: Install-org-node-2026-04-21-13-27-21
:ORG_GTD_PROJECT: Install org-node
:ORG_GTD_DEPENDS_ON: Check-if-non-roam-knowledge-can-be-integrated-2026-04-21-13-28-08
:END:
You first need a use-package call for org-mem:
#+begin_src emacs-lisp
  (use-package org-mem
    :custom
    (org-mem-watch-dirs (list "~/org/knowledge-base/"
  			    "~/org/non-roam-knowledge/"))
    :config
    (org-mem-updater-mode 1))
#+end_src
#+begin_src emacs-lisp
    (use-package org-node
      :init
      (bind-keys
       ("C-c k" . org-node-global-prefix-map)
       :map org-mode-map
       ("C-c n" . org-node-org-prefix-map))
      :custom
      (org-node-prefer-with-heading t)
      :config
      (org-node-cache-mode 1)

      (defun user/org-node-new-file (&optional title id)
        "Create a new file with a new node.
  Designed for `org-node-creation-fn'.  Customized insert to contain both
  a heading and a \"#+TITLE:\" block."
        (unless title (or (setq title org-node-proposed-title)
  			(error "Proposed title was nil")))
        (unless id (or (setq id org-node-proposed-id)
  		     (error "Proposed ID was nil")))
        (org-node-pop-to-fresh-file-buffer title)
        (insert "#+TITLE: " title
  	      "* " title
                "\n:PROPERTIES:"
                "\n:ID:       " id
                "\n:END:"
                "\n")
        (goto-char (point-max))
        (push (current-buffer) org-node--new-unsaved-buffers)
        (run-hooks 'org-node-creation-hook))
      
      (setq org-node-creation-fn user/org-node-new-file))
#+end_src
